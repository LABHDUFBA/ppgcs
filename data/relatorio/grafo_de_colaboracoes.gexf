      <node id="14" label="Maria Rosário Gonçalves de Carvalho">
        <viz:color r="51" g="160" b="44" a="1.0" />
        <attvalues>
          <attvalue for="0" value="http://lattes.cnpq.br/1298757533709756" />
          <attvalue for="1" value="0" />
          <attvalue for="2" value="27/03/2026" />
          <attvalue for="3" value="Doutora em Antropologia Social pela Universidade de São Paulo. Professora Titular e Emérita da Universidade Federal da Bahia, Faculdade de Filosofia e Ciências Humanas, Departamento de Antropologia e Etnologia. Bolsista de Produtividade de Pesquisa 1 do CNPq .Coordena o Programa de Pesquisas Sobre Povos Indígenas do Nordeste Brasileiro (PINEB) e o Fundo de Documentação Histórica Manuscrita sobre Índios da Bahia (FUNDOCIN). Tem se dedicado especialmente aos temas da Identidade, Etnicidade, Relações Raciais e Teoria Antropológica.. (Texto informado pelo autor)" />
