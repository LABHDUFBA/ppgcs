      <node id="6" label="Iara Maria de Almeida Souza">
        <viz:color r="51" g="160" b="44" a="1.0" />
        <attvalues>
          <attvalue for="0" value="http://lattes.cnpq.br/1266626414413147" />
          <attvalue for="1" value="20" />
          <attvalue for="2" value="23/03/2026" />
          <attvalue for="3" value="Fiz a graduação (1985), mestrado (1995) e doutorado (2004) em Ciências Sociais na Universidade Federal da Bahia, onde sou docente do Departamento de Sociologia. Integro o Programa de Pós-Graduação em Ciências Sociais, tendo exercido a coordenação entre 2009 e 2011. Pós-doutorado no Museu Nacional (UFRJ) e na UFMG. Faço pesquisa em sobre ciência e relação humano animal. (Texto informado pelo autor)" />
